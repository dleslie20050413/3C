  },  // end of so-called shore objects data
  // ================  method for drawing the so-called shore objects =============================
  drawShoresRivers: function()
  {
    ts=HZM.currentTileSize
    fx = document.getElementById("tfea").getContext("2d")
    fx.strokeStyle = "red";
    fx.lineWidth = ts/12;
    try
    {
      for ( p in this.shoreData )
      {
        namedSR=this.shoreData[p]
        try
        {
          x = namedSR["xpos"];
          x= x - HZM.currentMinXtile
          y= namedSR["ypos"]
          y=y-HZM.currentMinYtile
          var sLimit=42000  // the meaning of life times 1000
          for(count=0; count<sLimit; count++)// draw shore or river features
          {
            // even with the same basic data points the path differs slightly each time you observe it
            // this represents the 'shifting sands' of post Transit Alphito
            if (! namedSR["d"][count])break;
            d = namedSR["d"][count]
            dd = this.drawRivSeg(fx,x,y,ts,ts,d)
            x=dd[0]
            y=dd[1]
            
          }
        } catch (ex)
        {
          alert("ex:" + ex.message);
        }
      }
    } catch (exx)
    {
      alert("exx:" + exx.message)
    }
  },
  // ============ method for drawing details of shore objects ======================
  drawRivSeg: function(fx,x,y,w,h,d)
  {
    retval=[0,0]
    startx=x*w +(w/2)
    starty=y*h +(h/2)
    if ( d == "se")
    {
      seepx = x*w+w+(w/2)
      seepx1 = Math.ceil(startx + Math.random()*(w*.3))
      seepx2 = Math.ceil(seepx1 + Math.random()*(w*.4))
      seepx3 = Math.ceil(seepx2 + Math.random()*(w*.3))
      seepy = y*h+h+(h/2)
      seepy1 = Math.ceil(starty + Math.random() * (w*.3))
      seepy2 = Math.ceil(seepy1 + Math.random() * (w*.4))
      seepy3 = Math.ceil(seepy2 + Math.random() * (w*.3)) // se corner checked
      retval=[x+1,y+1]
      
      fx.beginPath();
      fx.moveTo(startx, starty)
      fx.lineTo(seepx1, seepy1 )
      fx.lineTo(seepx2, seepy2 )
      fx.lineTo(seepx3, seepy3 )
      fx.lineTo(seepx, seepy) // se corner checked
      fx.stroke();
    } else if ( d == "nw" )
    {
      nwepx1 = Math.ceil(startx - Math.random()*(w*.3))
      nwepx2 = Math.ceil(nwepx1 - Math.random()*(w*.4))
      nwepx3 = Math.ceil(nwepx2 - Math.random()*(w*.3))
      nwepy1 = Math.ceil(starty - Math.random() * (w*.3))
      nwepy2 = Math.ceil(nwepy1 - Math.random() * (w*.3))
      nwepy3 = Math.ceil(nwepy2 - Math.random() * (w*.3)) // nw corner checked
      nwepx = x*w - (w/2);
      nwepy = y*h - (h/2)
      retval=[x-1,y-1]
      
      fx.beginPath();
      fx.moveTo(startx, starty)
      fx.lineTo(nwepx1, nwepy1 )
      fx.lineTo(nwepx2, nwepy2 )
      fx.lineTo(nwepx3, nwepy3 )
      fx.lineTo(nwepx, nwepy) // nw corner checked
      fx.stroke();
    } else if ( d == "ne")
    {
      neepx=x*w+w+(w/2)
      neepy=y*h-(w/2)
      neepx1=Math.ceil(startx + Math.random()*(w*.3))
      neepx2=Math.ceil(neepx1 + Math.random()*(w*.4))
      neepx3=Math.ceil(neepx2 + Math.random()*(w*.3))
      neepy1=Math.ceil(starty - Math.random() * (w*.3))
      neepy2=Math.ceil(neepy1 - Math.random() * (w*.3))
      neepy3=Math.ceil(neepy2 - Math.random() * (w*.3)) // ne corner checked
      retval=[x+1,y-1]
      
      fx.beginPath();
      fx.moveTo(startx, starty)
      fx.lineTo(neepx1, neepy1 )
      fx.lineTo(neepx2, neepy2 )
      fx.lineTo(neepx3, neepy3 )
      fx.lineTo(neepx, neepy) // ne corner checked
      fx.stroke()
    } else if ( d == "sw")
    {
      swepx=x*w - (w/2)
      swepy=y*h+w+(w/2)
      swepx1=Math.ceil(startx - Math.random()*(w*.3))
      swepx2=Math.ceil(swepx1 - Math.random()*(w*.4))
      swepx3=Math.ceil(swepx2 - Math.random()*(w*.3))
      swepy1 = Math.ceil(starty + Math.random() * (w*.3))
      swepy2 = Math.ceil(swepy1 + Math.random() * (w*.4))
      swepy3 = Math.ceil(swepy2 + Math.random() * (w*.3)) // sw corner checked
      retval=[x-1,y+1]
      
      fx.beginPath();
      fx.moveTo(startx, starty)
      fx.lineTo(swepx1, swepy1 )
      fx.lineTo(swepx2, swepy2 )
      fx.lineTo(swepx3, swepy3 )
      fx.lineTo(swepx, swepy) // sw corner checked
      fx.stroke();
    } else if ( d == "n" )
    {
      nepx=x*w+(w/2)
      nepx1=Math.ceil(startx - Math.random()*(w*.3))
      nepx2=Math.ceil(nepx1 + Math.random()*(w*.4))
      nepx3=Math.ceil(nepx2 - Math.random()*(w*.3))
      nepy=(y*h)-(h/2)
      nepy1 = Math.ceil(starty - Math.random() * (w*.3))
      nepy2 = Math.ceil(nepy1 - Math.random() * (w*.4))
      nepy3 = Math.ceil(nepy2 - Math.random() * (w*.3))// north checked
      retval=[x,y-1]
      
      fx.beginPath();
      fx.moveTo(startx, starty)
      fx.lineTo(nepx1, nepy1 )
      fx.lineTo(nepx2, nepy2 )
      fx.lineTo(nepx3, nepy3 )
      fx.lineTo(nepx, nepy) // n side checked
      fx.stroke();
    } else if ( d == "s" )
    {
      sepx=(x*w+(w/2))
      sepx1=Math.ceil(startx - Math.random()*(w*.3))
      sepx2=Math.ceil(sepx1 + Math.random()*(w*.4))
      sepx3=Math.ceil(sepx2 - Math.random()*(w*.3))
      sepy=(y*h)+(h/2)+(h/2)+(h/2)
      sepy1 = Math.ceil(starty + Math.random() * (w*.3))
      sepy2 = Math.ceil(sepy1 + Math.random() * (w*.4))
      sepy3 = Math.ceil(sepy2 + Math.random() * (w*.3)) // south
      retval=[x,y+1]
      
      fx.beginPath();
      fx.moveTo(startx, starty)
      fx.lineTo(sepx1, sepy1 )
      fx.lineTo(sepx2, sepy2 )
      fx.lineTo(sepx3, sepy3 )
      fx.lineTo(sepx, sepy) // s side checked
      fx.stroke();
    } else if ( d == "e" )
    {
      eepx=(x*w+(w/2)+(w/2)+(w/2))
      eepx1=Math.ceil(startx + Math.random()*(w*.3))
      eepx2=Math.ceil(eepx1 + Math.random()*(w*.4))
      eepx3=Math.ceil(eepx2 + Math.random()*(w*.3))
      eepy=(y*h)+(h/2)
      eepy1 = Math.ceil(starty + Math.random() * (w*.3))
      eepy2 = Math.ceil(eepy1 - Math.random() * (w*.4))
      eepy3 = Math.ceil(eepy2 + Math.random() * (w*.3)) // east checked
      retval=[x+1,y]
      
      fx.beginPath();
      fx.moveTo(startx, starty)
      fx.lineTo(eepx1, eepy1 )
      fx.lineTo(eepx2, eepy2 )
      fx.lineTo(eepx3, eepy3 )
      fx.lineTo(eepx, eepy) // e side checked
      fx.stroke();
    } else if ( d == "w" )
    {
      wepx=x*w-(w/2)
      wepx1=Math.ceil(startx - Math.random()*(w*.3))
      wepx2=Math.ceil(wepx1 - Math.random()*(w*.4))
      wepx3=Math.ceil(wepx2 - Math.random()*(w*.3))
      wepy=(y*h)+(h/2)
      wepy1 = Math.ceil(starty + Math.random() * (w*.3))
      wepy2 = Math.ceil(wepy1 - Math.random() * (w*.4))
      wepy3 = Math.ceil(wepy2 + Math.random() * (w*.3)) // west c
      retval=[x-1,y]
      
      fx.beginPath();
      fx.moveTo(startx, starty)
      fx.lineTo(wepx1, wepy1 )
      fx.lineTo(wepx2, wepy2 )
      fx.lineTo(wepx3, wepy3 )
      fx.lineTo(wepx, wepy) // w side checked
      fx.stroke(); 
    }

    //ctx.fillStyle="red";
    //ctx.fillRect(x*w+(w/2), y*h+(h/2), 10, 10)
    return retval;
  },  
  //========================================  
  otherStuff:0  
  
} // end of shore objects
// try implementing the tiles as a class of objects, each instance of which draws itself
// some things, such as dried up shorelines and river beds are multi-tile objects that the tile does not draw when it draws itself
// such items are in the HZM object
class Tile
{
  constructor( xpos, ypos )
  {
    this.xpos=xpos;
    this.ypos=ypos;
    var yy = xpos == 0 ? (1000)+ypos :(xpos*1000)+ypos;
    yy= xpos>=0 && xpos < 10 ? "a00" + yy : xpos >= 10 && xpos < 100 ? "a0"+yy : "a"+yy
    yy = xpos == 0 ? yy.replace("1","0") : yy
    this.k=yy
    // from here is code useable only after tiles data is createDocumentFragment
    this.ttype = tiles[yy].ttype
    this.tstory=tiles[yy].tstory
    this.fertility=tiles[yy].fertility
    this.s=tiles[yy].s
    this.lvl=tiles[yy].lvl
    this.tname=tiles[yy].tname
  }
  drawBleakness( ctx, xp, yp, tileSize ){
    var bb = "a" + this.fertility
    var fs=ctx.fillStyle;
    try{
      ctx.fillStyle=HZM.bleakness[bb]["bgcc"];
    } catch (ex){
      console.log("ERR:" + bb)
      console.log("ERR:yy:" + this.k)
    }
     ctx.fillRect(xp+1, yp+1, tileSize-1, tileSize-1)
    // restore inits altered by local function 
    ctx.fillStyle=fs
  }
  drawAltitude(ctx, xp, yp, tileSize)
  {
    console.log("altitude")
    var bb = this.lvl > 0 ? "a" + this.lvl : "b" + Math.abs(this.lvl)
    var fs=ctx.fillStyle
    try{
      ctx.fillStyle=HZM.altitude[bb]["bgcc"];
    } catch (ex){
      console.log("altitude ERR: bb=" + bb)
      console.log("ERR:yy:" + this.k)
    }
    ctx.fillRect(xp+1, yp+1, tileSize-1, tileSize-1)
    ctx.fillStyle=fs
  }
  displaySettlerSymbols( ctx, xp, yp, tileSize )
  {
    if ( this.fertility < 320 ) return  // do this check here for maintainability, if we change the minimum settlement fertility, this will be a natural place to look
    // record inits used here
    var fs=ctx.fillStyle
    var currentlw = ctx.lineWidth
    var currentSstyle = ctx.strokeStyle;
    var ga=ctx.globalAlpha
    
    ctx.globalAlpha=1.0
    var bb = "a" + this.fertility;
    
    if (!this.ttype) {console.log("tile:" + this.xpos + "," + this.ypos); }  //record the tile then let the program crash; need to fix the bad data
    var ty=this.ttype
    if ( undefined == HZM.sColor[ty] ) { console.log("ty="+ty + "Tile:" + this.xpos + "," + this.ypos) } // another possible data problem
    ctx.fillStyle=HZM.sColor[ty][0]
    ctx.strokeStyle=HZM.sColor[ty][1]
    ctx.lineWidth = HZM.bleakness[bb]["sz"];
    var offset1=tileSize*(15/50)

    ctx.beginPath();
    ctx.arc(xp+offset1, yp+offset1, (tileSize*(5/50)+HZM.bleakness[bb]["sz"]), HZM.sColor[ty][2],HZM.sColor[ty][3]*Math.PI,HZM.sColor[ty][4])
    ctx.closePath();
    ctx.fill();

    ctx.beginPath();
    ctx.arc(xp+offset1, yp+offset1, (tileSize*(5/50)+HZM.bleakness[bb]["sz"]), HZM.sColor[ty][2],HZM.sColor[ty][3]*Math.PI,HZM.sColor[ty][4]) 
    ctx.closePath();
    ctx.stroke(); 

    //restore
    ctx.fillStyle=fs
    ctx.strokeStyle=currentSstyle;
    ctx.lineWidth=currentlw
    ctx.globalAlpha=ga
  }
  drawSlopes( ctx, xp, yp, tileSize )
  {
    //for ( var sc = 0; sc<this.s.length; sc++)
    //{
    //  console.log(this.s[sc]) ;HZM[this.s[sc]](ctx, xp, yp, tileSize)
    //}
  }
  drawPreTransit(ctx, xp, yp, tileSize )
  {
    var clr=null
    if (this.lvl > 0) { clr = HZM.preTransitWaters.land}
    else if (this.lvl < 0){ clr = HZM.preTransitWaters.sea}
    else if (this.lvl== 0){ clr = HZM.preTransitWaters.shore}
    var fs = ctx.fillStyle
    ctx.fillStyle=clr
    ctx.fillRect(xp+1, yp+1, tileSize-1, tileSize-1)
    ctx.fillStyle=fs   
  }
  drawTownNames(ctx1, xp, yp, tileSize )
  {
    var ts = tileSize
    if (this.fertility<320){return}
    var ctx = document.getElementById("ctext").getContext("2d")
    if (this.fertility==320){ ctx.font= Math.max(8, (12/50)*ts )+"px Arial";} // try this simple formula first
    else if (this.fertility==640){ ctx.font=Math.max(8, (14/50)*ts )+"px Arial";}
    else if (this.fertility==1280){ ctx.font=Math.max(8, (16/50)*ts )+"px Arial";}
    else if (this.fertility==2560){ ctx.font=Math.max(8, (18/50)*ts )+"px Arial";}
    else if (this.fertility==5120){ ctx.font=Math.max(8, (20/50)*ts )+"px Arial";}
    else if (this.fertility==10240){ ctx.font="bold "+Math.max(8, (22/50)*ts )+"px Arial";}
    else if (this.fertility==20480){ ctx.font="bold "+Math.max(8, (24/50)*ts )+"px Arial";}
    else if (this.fertility==40960){ ctx.font="bold "+Math.max(8, (26/50)*ts )+"px Arial";}
    else if (this.fertility==81920){ ctx.font="bold "+Math.max(8, (28/50)*ts )+"px Arial";}
    ctx.fillStyle="purple"
    ctx.globalAlpha=1.0;
    //console.log(this.tname +" font:"+ctx.font)
    //if ( this.tname == "Whittled Slip" ) console.log( "Whittled Slip:" + Math.floor(xp/tileSize)) 
    if (Math.floor(xp/tileSize) == 199 ){ 
      if (this.tname.length > 1) 
        { ctx.fillText( this.tname, (xp-tileSize)+(tileSize*(15/50)), yp+(tileSize*(15/50)));}
    }
    else {ctx.fillText( this.tname, xp+(tileSize*(15/50)), yp+(tileSize*(15/50)));}
    
  }

  drawSelf( ctx ) // ctx is the 2D context of a canvas object
  {
    //console.log("ds")
    // test whether to draw the tile or not; based on tile xypos
    if ( this.xpos < HZM.currentMinXtile) return
    //console.log("ds 3")    
    if ( this.xpos > HZM.currentMaxXtile) return
    //console.log("ds 4")
    if ( this.ypos < HZM.currentMinYtile) return
    //console.log("ds 5")
    if ( this.ypos > HZM.currentMaxYtile) return
    //console.log("ds 6")    
    // passed xypos test now test based on pixel position
    var tileSize = HZM.currentTileSize
    //console.log("ds 7")    
    var xp = (this.xpos-HZM.currentMinXtile)*HZM.currentTileSize // left
    //console.log("ds 8")    
    var yp = (this.ypos-HZM.currentMinYtile)*HZM.currentTileSize // top
    //console.log("ds 9 xp + HZM.currentTileSize=" + xp + HZM.currentTileSize +",HZM.currentMaxXpx:"+HZM.currentMaxXpx)
    if (( xp + HZM.currentTileSize) > HZM.currentMaxXpx) return
    //console.log("ds 10")
    if (( yp + HZM.currentTileSize) > HZM.currentMaxYpx) return
    //console.log("ds 2 xp=" +xp + "yp="+yp)
    // draw tile outline
    //ctx.strokeStyle="black"
    //ctx.lineWidth=5
    ctx.strokeRect(xp, yp, tileSize, tileSize); // canvas method
    // draw background
    if (HZM.currentDisplay == 0) // post transit background
    {
      //console.log("ds 11")    
      this.drawBleakness( ctx, xp, yp, tileSize )
    //console.log("ds 12")
      this.drawSlopes( ctx, xp, yp, tileSize )
    } else if (HZM.currentDisplay == 1) {
      this.drawAltitude( ctx, xp, yp, tileSize )
      this.drawSlopes( ctx, xp, yp, tileSize )
    } else{ // pre transit background
      this.drawPreTransit(ctx, xp, yp, tileSize )
    //console.log("ds 13")
    }
    //console.log("ds 14")
    this.displaySettlerSymbols( ctx, xp, yp, tileSize )
    //console.log("ds 15")
    this.drawTownNames( ctx, xp, yp, tileSize )
    //console.log("ds 16")
  }
}