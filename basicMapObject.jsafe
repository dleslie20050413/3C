  //=========================================
  kasyaarCanyon: function( tiles)
  {
    //console.log("Kasyaar Canyon")
    ts=HZM.currentTileSize
    ctx=document.getElementById("main").getContext("2d")
    fx = document.getElementById("tfea").getContext("2d")
    
    // record start values
    startAlpha=fx.globalAlpha
    fs=fx.fillStyle
    startFont=ctx.font
    // set local values
    fx.globalAlpha=0.5
    fx.fillStyle="#B0E0E6" //powderblue
    
    var xc = 45
    var newXC = xc
    var yspot=177
    var curlvl=0
    var newCurlvl=0

    var keepgoing=true
    var escapehatch=0
    fx.fillRect((x-HZM.currentMinXtile)*ts,(yspot-HZM.currentMinYtile)*ts,ts,ts)
    do{
      yspot--
      for ( var x = xc-2; x < xc+2; x++)
      {
        xkey = x < 10 ? "00" + x : x < 100 ? "0" + x: x
        ykey = yspot < 10 ? "00" + yspot : yspot < 100 ? "0" + yspot: yspot
        ky = "a" + xkey + ykey
        if (!tiles[ky] || tiles[ky].lvl < -1999) { /*console.log("Kasyaar:"+ky);*/ keepgoing=false; break }
        if (tiles[ky].lvl <= curlvl)
        {
          if (tiles[ky].lvl < newCurlvl){ newCurlvl = tiles[ky].lvl; newXC = x}
          fx.fillRect(((x)-HZM.currentMinXtile)*ts,(yspot-HZM.currentMinYtile)*ts,ts,ts)
        }
      }
      xc = newXC
    } while (keepgoing && (escapehatch++ < 1000))

      let fontS = Math.floor(ts *0.8)
      ctx.font="bold "+fontS+"px Arial";
      ctx.fillStyle="black"
      ctx.globalAlpha=.5
      ctx.fillText( "Kasyaar Canyon", (44-HZM.currentMinXtile)*ts, (162-HZM.currentMinYtile)*ts);  
    // restore start values
    fx.globalAlpha=startAlpha
    fx.fillStyle=fs
    ctx.font=startFont
    HZM.scrollToXY(44-HZM.currentMinXtile,162-HZM.currentMinYtile)
  }
}
  // ========================= dry shore and river beds ===============================
shoreObjects={
  shoreData:{
    umurmurShore:{xpos:0, ypos:183, d:["e","e","ne","se","se","ne","n","e","ne",/**/"e","e","e","se","se","se","e","se","e","e","e","e","e","se","se","se","se"/**/,"e","e","e","e","e","e","e","e","e"],decsription:""},
