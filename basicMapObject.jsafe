  S: function(ctx,xp,yp,tilesize)
  {
    console.log("S")
    var w = tilesize
    var h = tilesize
    ctx.beginPath();// start path for arrow with base at south and apex at center
    ctx.moveTo(xp+Math.floor(h*(4/10)),yp+h); // 440,50
    ctx.lineTo(xp+Math.floor(h*(6/10)),yp+h);// 450, 50
    ctx.lineTo(xp+Math.floor(w/2),yp+Math.floor(h/2));// 445, 25
    ctx.closePath(); //close path for arrow with base at south and apex at center
    ctx.stroke(); //draw arrow with base at south and apex at center
  },
  s: function(ctx,xp,yp,tilesize) // vale south
  {
    var w = tilesize
    var h = tilesize
    ctx.beginPath();// start path of arrow with base in center and point to the south
    ctx.moveTo(xp+Math.floor(w*(20/50)),yp+Math.floor(h*(25/50)));// 435,445: 445, 470
    ctx.lineTo(xp+Math.floor(w*(30/50)),yp+Math.floor(h*(25/50)));// 455,445
    ctx.lineTo(xp+Math.floor(w*(25/50)),yp+h);// 445, 470
    ctx.closePath();// finish path of arrow with base in center and point to the south
    ctx.stroke();// draw arrow with base in center and point to the south
  },
  N: function(ctx,xp,yp,tilesize) // peak north
  {
    var w = tilesize
    var h = tilesize
    ctx.beginPath();// start path base north, apex center
    ctx.moveTo(xp+Math.floor(h*(4/10)),yp);
    ctx.lineTo(xp+Math.floor(h*(6/10)),yp);
    ctx.lineTo(xp+Math.floor(w/2),yp+Math.floor(h/2));
    ctx.closePath();// finish path base north, apex center
    ctx.stroke();// stroke path base north, apex center    
  },
  n: function(ctx,xp,yp,tilesize) // vale north
  {
    var w = tilesize
    var h = tilesize
    ctx.beginPath();// start path of arrow with base in center and point to the north
    ctx.moveTo(xp+Math.floor(w*(20/50)),yp+Math.floor(h*(25/50)));// 
    ctx.lineTo(xp+Math.floor(w*(30/50)),yp+Math.floor(h*(25/50)));//
    ctx.lineTo(xp+Math.floor(w*(25/50)),yp);// 445, 470
    ctx.closePath();// finish path of arrow with base in center and point to the north
    ctx.stroke();// draw arrow with base in center and point to the north
  }, 
  E: function(ctx,xp,yp,tilesize) // peak east
  {
    var w = tilesize
    var h = tilesize
    ctx.beginPath();// start path for arrow with base at east and apex at center
    ctx.moveTo(xp+w,yp+Math.floor(h*(2/5))); // 470,20
    ctx.lineTo(xp+w,yp+Math.floor(h*(3/5)));// 470 30
    ctx.lineTo(xp+Math.floor(w/2),yp+Math.floor(h/2));// 445, 25
    ctx.closePath(); //close path for arrow with base at east and apex at center
    ctx.stroke(); //draw arrow with base at east and apex at center          
  },
  e: function(ctx,xp,yp,tilesize) // vale east
  {
    var w = tilesize
    var h = tilesize
    ctx.beginPath();// start path of arrow with base in center and point to the east
    ctx.moveTo(xp+Math.floor(w*(25/50)),yp+Math.floor(h*(20/50)));// 
    ctx.lineTo(xp+Math.floor(w*(25/50)),yp+Math.floor(h*(30/50)));//
    ctx.lineTo(xp+w,(yp+Math.floor(h*(25/50))));// 445, 470
    ctx.closePath();// finish path of arrow with base in center and point to the east
    ctx.stroke();// draw arrow with base in center and point to the east
  },

  W: function(ctx,xp,yp,tilesize)// peak west
  {
    var w = tilesize
    var h = tilesize
    ctx.beginPath();// start path for arrow with base at west and apex at center
    ctx.moveTo(xp,yp+Math.floor(h*(2/5))); // 420,20
    ctx.lineTo(xp,yp+Math.floor(h*(3/5)));// 420 30
    ctx.lineTo(xp+Math.floor(w/2),yp+Math.floor(h/2));// 445, 25
    ctx.closePath(); //close path for arrow with base at west and apex at center
    ctx.stroke(); //draw arrow with base at west and apex at cente
  },
  
  w: function(ctx,xp,yp,tilesize) // vale west
  {
    var w = tilesize
    var h = tilesize
    ctx.beginPath();// start path of arrow with base in center and point to the west
    ctx.moveTo(xp+Math.floor(w*(25/50)),yp+Math.floor(h*(20/50)));// 
    ctx.lineTo(xp+Math.floor(w*(25/50)),yp+Math.floor(h*(30/50)));//
    ctx.lineTo(xp,yp+Math.floor(h*(25/50)));// 445, 470
    ctx.closePath();// finish path of arrow with base in center and point to the west
    ctx.stroke();// draw arrow with base in center and point to the west
  },
  A: function(ctx,xp,yp,tilesize) // peak northwest
  {
    var w = tilesize
    var h = tilesize
    ctx.beginPath();// start path for arrow with base at northwest and apex at center
    ctx.moveTo(xp+Math.floor(w*(1/10)),yp); // 420,20
    ctx.lineTo(xp,yp+Math.floor(h*(1/10)));// 420 30
    ctx.lineTo(xp+Math.floor(w/2),yp+Math.floor(h/2));// 445, 25
    ctx.closePath(); //close path for arrow with base at northwest and apex at center
    ctx.stroke(); //draw arrow with base at northwest and apex at center
  },
  a: function(ctx,xp,yp,tilesize) // vale northwest
  {
    var w = tilesize
    var h = tilesize
    ctx.beginPath();// start path of arrow with base in center and point to the northwest
    ctx.moveTo(xp+Math.floor(w*(25/50)),yp+Math.floor(h*(20/50)));
    ctx.lineTo(xp+Math.floor(w*(20/50)),yp+Math.floor(h*(25/50)));
    ctx.lineTo(xp,yp);//
    ctx.closePath();// finish path of arrow with base in center and point to the northwest
    ctx.stroke();// draw arrow with base in center and point to the northwest
  },
  B: function(ctx,xp,yp,tilesize) // peak northeast
  {
    var w = tilesize
    var h = tilesize
    ctx.beginPath();// start path for arrow with base at northeast and apex at center
    ctx.moveTo(xp+Math.floor(w*(9/10)),yp); // 420,20
    ctx.lineTo(xp+w,yp+Math.floor(h*(1/10)));// 420 30
    ctx.lineTo(xp+Math.floor(w/2),yp+Math.floor(h/2));// 445, 25
    ctx.closePath(); //close path for arrow with base at northeast and apex at center
    ctx.stroke(); //draw arrow with base at northeast and apex at cente
  },
  b: function(ctx,xp,yp,tilesize) // vale northeast
  {
    var w = tilesize
    var h = tilesize
    ctx.beginPath();// start path of arrow with base in center and point to the northeast
    ctx.moveTo(xp+Math.floor(w*(25/50)),yp+Math.floor(h*(20/50)));
    ctx.lineTo(xp+Math.floor(w*(30/50)),yp+Math.floor(h*(25/50)));//
    ctx.lineTo(xp+w,yp);
    ctx.closePath();// finish path of arrow with base in center and point to the northeast
    ctx.stroke();// draw arrow with base in center and point to the northeast
  },
  C: function(ctx,xp,yp,tilesize) // peak southeast
  {
    var w = tilesize
    var h = tilesize
    ctx.beginPath();// start path for arrow with base at southeast and apex at center
    ctx.moveTo(xp+Math.floor(w*(9/10)),yp+h); // 420,20
    ctx.lineTo(xp+w,yp+Math.floor(h*(9/10)));// 420 30
    ctx.lineTo(xp+Math.floor(w/2),yp+Math.floor(h/2));// 445, 25
    ctx.closePath(); //close path for arrow with base at southeast and apex at center
    ctx.stroke(); //draw arrow with base at southeast and apex at center    
  },
  c: function(ctx,xp,yp,tilesize) // vale southeast
  {
    var w = tilesize
    var h = tilesize
    ctx.beginPath();// start path of arrow with base in center and point to the southeast
    ctx.moveTo(xp+Math.floor(w*(30/50)),yp+Math.floor(h*(25/50)));// 
    ctx.lineTo(xp+Math.floor(w*(25/50)),yp+Math.floor(h*(30/50)));//
    ctx.lineTo(xp+w,yp+h);// 445, 470
    ctx.closePath();// finish path of arrow with base in center and point to the southeast
    ctx.stroke();// draw arrow with base in center and point to the southeast
  },
  D: function(ctx,xp,yp,tilesize) // peak southwest
  {
    var w = tilesize
    var h = tilesize
    ctx.beginPath();// start path for arrow with base at southwest and apex at center
    ctx.moveTo(xp,yp+Math.floor(h*(9/10))); // 420,20
    ctx.lineTo(xp+Math.floor(w*(1/10)),yp+h);// 420 30
    ctx.lineTo(xp+Math.floor(w/2),yp+Math.floor(h/2));// 445, 25
    ctx.closePath(); //close path for arrow with base at southwest and apex at center
    ctx.stroke(); //draw arrow with base at southwest and apex at center
  },
  d: function(ctx,xp,yp,tilesize) // vale southwest
  {
    var w = tilesize
    var h = tilesize
    ctx.beginPath();// start path of arrow with base in center and point to the southwest
    ctx.moveTo(xp+Math.floor(w*(25/50)),yp+Math.floor(h*(30/50)))
    ctx.lineTo(xp+Math.floor(w*(20/50)),yp+Math.floor(h*(25/50)));//
    ctx.lineTo(xp,yp+h);// 445, 470
    ctx.closePath();// finish path of arrow with base in center and point to the southwest
    ctx.stroke();// draw arrow with base in center and point to the southwes
  },
  
  // other things
  other:null
}
Features={
  heartOfTheWorld: function(tiles)
  {
    //console.log("heartOfTheWorld")
    ts=HZM.currentTileSize
    ctx=document.getElementById("main").getContext("2d")
    //104 to 131 y
    //70 to 95 x
    fx = document.getElementById("tfea").getContext("2d")
    // record init values
    startAlpha=fx.globalAlpha
    fs=fx.fillStyle
    startFont=ctx.font
    // set local values
    fx.globalAlpha=0.5
    fx.fillStyle="#B0E0E6" //powderblue
    for (let x = 70; x < 95; x++) {
      for (let y=104; y<131; y++)
      {
        if (x >= HZM.currentMaxXtile || y>= HZM.currentMaxYtile || x < HZM.currentMinXtile || y < HZM.currentMinYtile) continue;
        xkey = x < 10 ? "00" + x : x < 100 ? "0" + x: x
        ykey = y < 10 ? "00" + y : y < 100 ? "0" + y: y
        ky = "a" + xkey + ykey 
        //console.log(ky)
        if (tiles[ky].lvl<-2050)
        {
          fx.fillRect((x-HZM.currentMinXtile)*ts,(y-HZM.currentMinYtile)*ts,ts,ts)
        }
      }
    }
    
      let fontS = Math.floor(ts *0.8)
      ctx.font="bold "+fontS+"px Arial";
      ctx.fillStyle="black"
      ctx.globalAlpha=.5
      ctx.fillText( "Heart Of The World", (82-HZM.currentMinXtile )*ts, (117-HZM.currentMinYtile)*ts);  
    
    // restore init values
    fx.globalAlpha=startAlpha
    fx.fillStyle=fs
    ctx.font=startFont
    //console.log(" end heartOfTheWorld")
    //HZM.scrollToXY(82,117);
  },
  //=====================================================
  enubadFan: function( tiles )
  {
    //console.log("Enubad Fan")
    ts=HZM.currentTileSize
    ctx=document.getElementById("main").getContext("2d")
    fx = document.getElementById("tfea").getContext("2d")
    // record init values
    startAlpha=fx.globalAlpha
    fs=fx.fillStyle
    startFont=ctx.font
    
    // set local values
    fx.globalAlpha=0.5
    fx.fillStyle="#B0E0E6"
    fx.strokeStyle="black"
    fx.lineWidth=5
    
    // fan starts at 30,57
    // mid 68, 108: bottom 58, 117:  top 70, 98
    //unlit 59.119
    //xypos has to be adjusted when the map size is not the default.
    // startX = 30-HZM.currentMinXtile
      startX = 30-HZM.currentMinXtile
      startY = 57-HZM.currentMinYtile
        fx.beginPath()
        fx.moveTo(startX*ts,startY*ts)
        fx.lineTo((startX+2)*ts,(startY+9)*(ts))//+(ts*6/50)))
        fx.lineTo((startX+6)*(ts),(startY+13)*(ts))//+(ts*16/50)))
        fx.lineTo((startX+7)*ts,(startY+16)*(ts))//+(ts*16/50)))
        fx.lineTo((startX+9)*ts,(startY+21)*(ts))//+(ts*14/50)))
        fx.lineTo((startX+12)*ts,(startY+27)*(ts))//+(ts*16/50)))
        fx.lineTo((startX+15)*ts,(startY+34)*(ts))//+(ts*16/50)))
        fx.lineTo((startX+18)*ts,(startY+41)*(ts))//+(ts*16/50)))
        fx.lineTo((startX+20)*ts,(startY+49)*(ts))//+(ts*15/50)))
        fx.lineTo((startX+23)*ts,(startY+63)*ts)
        fx.lineTo((startX+29)*ts,(startY+59)*(ts))//-(ts*9/50)))
        fx.lineTo((startX+35)*ts,(startY+53)*(ts))
        fx.lineTo((startX+40)*ts,(startY+43)*(ts))
        fx.lineTo((startX+37)*ts,(startY+34)*(ts))//-(ts*12/50)))
        fx.lineTo((startX+32)*ts,(startY+30)*(ts))//-(ts*11/50)))
        fx.lineTo((startX+31)*ts,(startY+29)*(ts))//-(ts*10/50)))
        fx.lineTo((startX+27)*ts,(startY+25)*(ts))//-(ts*9/50)))
        fx.lineTo((startX+28)*ts,(startY+21)*(ts))//-(ts*8/50)))
        fx.lineTo((startX+22)*ts,(startY+17)*(ts))//-(ts*7/50)))
        fx.lineTo((startX+17)*ts,(startY+13)*(ts))//-(ts*6/50)))
        fx.lineTo((startX+13)*ts,(startY+11)*(ts))//-(ts*5/50)))
        fx.lineTo((startX+9)*ts,(startY+5)*(ts))//-(ts*4/50)))
        fx.closePath()
        fx.stroke()
        fx.fill()
    // 45, 83
      fs=ts*1.5
      ctx.font="bold "+fs+"px Arial";
      ctx.fillStyle="black"
      ctx.globalAlpha=.99
      ctx.fillText( "Enubad Fan", (44-HZM.currentMinXtile)*ts, (83-HZM.currentMinYtile)*ts); 
      ctx.strokeStyle="lime"
      ctx.strokeText("Enubad Fan", (44-HZM.currentMinXtile)*ts, (83-HZM.currentMinYtile)*ts)
    
    // restore init values
    fx.globalAlpha=startAlpha
    fx.fillStyle=fs
    ctx.font=startFont
    //console.log(" end enubadFan")
    //HZM.scrollToXY(44,83);
  },
  //==================================================================
  subspororoCanyon: function(tiles)
  {
    //console.log("Subsporo Canyon")
    ts=HZM.currentTileSize
    //console.log("Subsporo Canyon ts="+ts)
    ctx=document.getElementById("main").getContext("2d")
    //console.log("Subsporo Canyon ctx")
    fx = document.getElementById("tfea").getContext("2d")
    //console.log("Subsporo Canyon fx")
    // record start values
    startAlpha=fx.globalAlpha
    //console.log("Subsporo Canyon sv")
    fs=fx.fillStyle
    startFont=ctx.font

    // set local values
    fx.globalAlpha=0.5
    fx.fillStyle="#B0E0E6" //powderblue
    // start by listing some tiles that are start the Canyon
    var xspotMin=30
    var xspotMax=30
    var yspot=177
    var curlvl=-300
    var newCurlvl=-300
    //console.log("Subsporo Canyon lv")
    // now fan to the north, choose any tiles that are equal or lower, stop when y reaches 155 or depth value < -2000
    var keepgoing=true
    var zzz=2000
    do
    {
      zzz++
      //console.log("do")
      for ( x=xspotMin-2; x<xspotMax+2;x++)
      {
        //console.log("for")
        if (x > 40) continue
        if (x >= HZM.currentMaxXtile || yspot>= HZM.currentMaxYtile || x < HZM.currentMinXtile || yspot < HZM.currentMinYtile) continue;
        xkey = x < 10 ? "00" + x : x < 100 ? "0" + x: x
        ykey = yspot < 10 ? "00" + yspot : yspot < 100 ? "0" + yspot: yspot
        ky = "a" + xkey + ykey 
        //console.log("ky:"+ky+"keepgoing:"+keepgoing)
        if (!tiles[ky]) { console.log(yy); keepgoing=false; break }
        if (tiles[ky].lvl <= curlvl)
        {
          if (x<xspotMin) xspotMin=x
          if (x>xspotMax) xspotMax=x
          if (tiles[ky].lvl<curlvl) newCurlvl = tiles[ky].lvl
          //console.log("new level:" + newCurlvl)
          fx.fillRect((x-HZM.currentMinXtile)*ts,(yspot-HZM.currentMinYtile)*ts,ts,ts)
        }
        //console.log("ky:"+ky+"keepgoing:"+keepgoing)
      }
      yspot--
      curlvl=newCurlvl
      if (curlvl<-2000) break
      if (zzz>3000) keepgoing=false
    } while (keepgoing)
      // fix one anomoly
    for ( x=29; x<32;x++)
    {
      yspot=173
      fx.fillRect((x-HZM.currentMinXtile)*ts,(yspot-HZM.currentMinYtile)*ts,ts,ts)
    }
      let fontS = Math.floor(ts *0.8)
      fx.font="bold "+fontS+"px Arial";
      fx.fillStyle="black"
      fx.globalAlpha=.6
      fx.fillText( "Subsporo Canyon", (30-HZM.currentMinXtile)*ts, (165-HZM.currentMinYtile)*ts);  
    
    // restore start values
    fx.globalAlpha=startAlpha
    fx.fillStyle=fs
    ctx.font=startFont
    //console.log("done with subspororoCanyon")
    HZM.scrollToXY(32,160);
    
  },
  //====================================================
  stormWomb: function(tiles)
  {
    //console.log("Storm Womb")
    ts=HZM.currentTileSize
    ctx=document.getElementById("main").getContext("2d")
    fx = document.getElementById("tfea").getContext("2d")
    
    // record start values
    startAlpha=fx.globalAlpha
    fs=fx.fillStyle
    startFont=ctx.font
    // set local values
    fx.globalAlpha=0.5
    fx.fillStyle="#B0E0E6" //powderblue
    //  105,63 to 132,83; if the depth is -1500 it's part of the feature
    for (var x=105; x < 133; x++)
    {
      for ( var y = 63; y<84; y++)
      {
        if (x >= HZM.currentMaxXtile || y>= HZM.currentMaxYtile || x < HZM.currentMinXtile || y < HZM.currentMinYtile) continue;
        xkey = x < 10 ? "00" + x : x < 100 ? "0" + x: x
        ykey = y < 10 ? "00" + y : y < 100 ? "0" + y: y
        ky = "a" + xkey + ykey 
        if ( tiles[ky].lvl == -1500)
        {
          fx.fillRect((x-HZM.currentMinXtile)*ts,(y-HZM.currentMinYtile)*ts,ts,ts)
        }
      }
    }
    let fontS = Math.floor(ts *0.8)
    ctx.font="bold "+fontS+"px Arial";
    ctx.fillStyle="black"
    ctx.globalAlpha=.5
    ctx.fillText( "Storm Womb", (116-HZM.currentMinXtile)*ts, (72-HZM.currentMinYtile)*ts);  
    // restore start values
    fx.globalAlpha=startAlpha
    fx.fillStyle=fs
    ctx.font=startFont 
    HZM.scrollToXY(116-HZM.currentMinXtile,72-HZM.currentMinYtile);
  },
