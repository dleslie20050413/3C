/* somewhat abstracted from the base canvas objects but not actually independent. Canvas properties and methods are used
*/
HZM={ // (H)abitable (Z)one (M)apt this can be an object and not a class because there is only one map
  //Map is already a Javascript defined object
  // define the biggest we will allow the map canvas to be in pixels
  // and the biggest area we will allow it to depict in tiles
  absMaximumXpx:10000,
  absMaximumYpx:10000,
  absMinimumXpx:1000,
  absMinimumYpx:1000,
  // these are absolute only because this defines the paramaters of the habitable zone
  // if the tiles are changed to describe a size that is something other than 5 miles then the numbers could change
  absMaximumXtile:200, // 200-1=199
  absMaximumYtile:200, // 200-1=199
  absMinimumXtile:0,
  absMinimumYtile:0,
  //tileSize:50,// in px 
  // define the current size of the map canvas in pixels
  // and the current area it depicts in tiles
  currentMaxXpx:this.absMaximumXpx,
  currentMaxYpx:this.absMaximumYpx,
  currentMinXpx:null,
  currentMinYpx:null,
  currentMaxXtile:null,
  currentMaxYtile:null,
  currentMinXtile:null,
  currentMinYtile:null,
  currentRowSize:null,
  currentColSize:null,
  currentTileSize:null,
  currentDisplay:0,  // 0 is post transit fertility, 
                     // 1 is altitude, 
                     // 2 is pre transit 
  initMap: function()
  {
    console.log("init map")
    this.currentMaxXpx=this.absMaximumXpx
    this.currentMaxYpx=this.absMaximumYpx
    this.currentMinXpx=this.absMinimumXpx
    this.currentMinYpx=this.absMinimumYpx
    this.currentMaxXtile=this.absMaximumXtile
    this.currentMaxYtile=this.absMaximumYtile
    this.currentMinXtile=this.absMinimumXtile
    this.currentMinYtile=this.absMinimumYtile
    this.currentRowSize=this.absMaximumXtile-this.absMinimumXtile             // calculated
    this.currentColSize=this.absMaximumYtile-this.absMinimumYtile            // calculated
    this.currentTileSize=this.currentMaxXpx/this.currentRowSize           // calculated
  },
  reset: function ()
  {
    console.log("reset")
    this.currentMaxXpx=this.absMaximumXpx
    this.currentMaxYpx=this.absMaximumYpx
    this.currentMinXpx=this.absMinimumXpx
    this.currentMinYpx=this.absMinimumYpx
    this.currentMaxXtile=this.absMaximumXtile
    this.currentMaxYtile=this.absMaximumYtile
    this.currentMinXtile=this.absMinimumXtile
    this.currentMinYtile=this.absMinimumYtile
    this.currentRowSize=this.absMaximumXtile-this.currentMinXtile
    this.currentColSize=this.currentMaxYtile-this.currentMinYtile
    this.currentTileSize=this.absMaximumXpx/this.currentRowSize  
  },  
  adjustArea: function ( pxil, rsize, lft, tp)
  { // adjust parameters for displaying map portions
    console.log("adjustArea pxil:" +  pxil + ",rsize=" + rsize + ",lft=" + lft +", tp=" + tp)
    mc = document.getElementById("main")
    mc2 = document.getElementById("ctext")
    mc3 = document.getElementById("tfea")
    ctx= mc.getContext("2d");
    ctx2=mc2.getContext("2d");
    ctx3=mc3.getContext("2d");
    ctx.clearRect(0,0,this.currentMaxXpx,this.currentMaxYpx)
    ctx2.clearRect(0,0,this.currentMaxXpx,this.currentMaxYpx)
    ctx3.clearRect(0,0,this.currentMaxXpx,this.currentMaxYpx)
   
    
    this.currentColSize = (tp + rsize) <= this.absMaximumYtile ? rsize : this.absMaximumYtile - tp 
    this.currentRowSize = (lft + rsize) <= this.absMaximumXtile ? rsize : this.absMaximumXtile - lft
    this.currentMinXtile=lft
    this.currentMinYtile=tp
    this.currentMaxXtile=this.currentMinXtile+this.currentRowSize
    this.currentMaxYtile=this.currentMinYtile+this.currentColSize
    this.currentTileSize=Math.min(Math.ceil(pxil/this.currentRowSize),Math.ceil(pxil/this.currentColSize))
    
    this.currentMaxXpx=(this.currentMaxXtile - this.currentMinXtile)*this.currentTileSize
    this.currentMaxYpx=(this.currentMaxYtile - this.currentMinYtile)*this.currentTileSize
    this.currentMinXpx=0
    this.currentMinYpx=0
    
        
        mc.width=this.currentMaxXpx //HZM.currentMaxXpx
        mc.height=this.currentMaxYpx   
        mc2.width=this.currentMaxXpx//HZM.currentMaxXpx
        mc2.height=this.currentMaxYpx   
        mc3.width=this.currentMaxXpx //HZM.currentMaxXpx
        mc3.height=this.currentMaxYpx 
    
  },
  showArea: function() // for now ctx is only for main canvas
  {
    console.log("showArea MinX:" + HZM.currentMinXtile + " maxX:" + HZM.currentMaxXtile  + " minY:" + HZM.currentMinYtile + "maxY:" + HZM.currentMaxYtile )
    ctx=document.getElementById("main").getContext("2d")
    for( var x=HZM.currentMinXtile; x<HZM.currentMaxXtile; x++)
    {
      for( var y=HZM.currentMinYtile; y<HZM.currentMaxYtile; y++)
      {
        xkey = x < 10 ? "00" + x : x < 100 ? "0" + x: x
        ykey = y < 10 ? "00" + y : y < 100 ? "0" + y: y
        key = "a" + xkey + ykey 
        if ( tiles[key]) {
          xp=tiles[key].xpos
          yp=tiles[key].ypos
          t= new Tile(xp,yp)
          t.drawSelf(ctx)
        }  else {console.log( "no tile with key:" + key) }
      }
    }
    for ( p in Features ) { /*console.log(p);*/ Features[p](tiles)}
    shoreObjects.drawShoresRivers()
    HZM.scrollToXY(HZM.currentMinXtile+Math.floor((HZM.currentRowSize/2)), HZM.currentMinYtile+(Math.floor(HZM.currentColSize/2)))
    document.getElementById("firstform").style.display="none"
  },
  setTileArea: function( minX, minY, maxX, maxY)
  {
    console.log("setTileArea")
    this.currentMaxXtile=maxX
    this.currentMaxYtile=maxY
    this.currentMinXtile=minX
    this.currentMinYtile=minY
    this.currentRowSize=maxX-minX
    this.currentColSize=maxY-minY
    this.currentTileSize=this.currentMaxXpx/this.currentRowSize
  },
  setPxArea: function( minX, minY, maxX, maxY)
  {
    console.log("setPxArea")
    this.currentMaxXpx=maxX
    this.currentMaxYpx=maxY
    this.currentMinXpx=minX
    this.currentMinYpx=minY
    this.currentTileSize=this.currentMaxXpx/this.currentRowSize
  },
  getViewportSize: function()
  {
    console.log("getViewportSize")
    if (window.innerWidth != null) return {w: window.innerWidth, h:window.innerHeight }
    return null;
  },
  scrollToXY: function (vx, vy){
    //document.getElementById("placingForm").scrollIntoView()
    console.log("scrollToXY:" +vx + "," + vy)
    // ================ it might be required that the screen be redrawn; start here ================
    tmpx = vx
    tmpy = vy
    scTo=document.getElementById("placingForm")
    scTo.style.display="inline";
    tmp=((tmpy-this.currentMinYtile)*this.currentTileSize)
    scTo.style.top=tmp+"px"
    tmp=((tmpx-this.currentMinXtile)*this.currentTileSize)
    scTo.style.left=tmp+"px"
    //console.log("x"+tmpx+", y="+tmpy+" tileSize="+this.currentTileSize+", top=" + scTo.style.top +", left=" + scTo.style.left)
    scTo.scrollIntoView()
    scTo.style.display="none";
  },
  tileKeyFromXY: function(x,y)
  {
    console.log("tileKeyFromXY")
    var xkey = x < 10 ? "00" + x : x < 100 ? "0" + x: x
    var ykey = y < 10 ? "00" + y : y < 100 ? "0" + y: y
    var ky =  "a" + xkey + ykey
    return ky
  },
