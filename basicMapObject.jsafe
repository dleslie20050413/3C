    PSSeaStoutToSSMines:{xpos:71,ypos:156,d:["e","e","ne","e","e","ne","e","e","ne","e","e","ne","e","e","ne","e","e","ne","e","e","ne","e","se","e","se","ne","e","se","ne","ne","n","ne","n","e","s","se","e","s","s","s","se","se","se","se","se","se","e","se","e","se","ne","ne","se","s","sw","s","s","s","se","s","s","s","se","s","se","s","se","s","se","e","e","ne","ne","n","n","n","e","e","e","e","s","s","e","s","se","s","s","se","e","e","se","se","se","s","e","n","ne","ne","se","s","s","e","s","e","e","se","se","e","e","se","e","e","ne","ne","e","ne","ne","e","e","e","ne","ne","s","e","ne","ne","se","se","s","se","e","e","se","e","e","se","e","e","ne","ne","ne","e","ne","ne","ne","ne","e","ne","ne","ne","ne","n","ne","ne"],description:"Parched Sea Shore Stout Sail Hold to SharpShield Mines"},

